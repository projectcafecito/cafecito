---
const home = Astro.url.pathname === '/';
const productUrl = home ? '#products' : '/#products';
---

<nav class="top-nav">
  <div class="container top-nav-inner">
    <a href="/" class="brand">
      <img src="/images/cafecito.png" alt="Project Cafecito logo" />
      <span>Project Cafecito</span>
    </a>
    <details class="mobile-menu">
      <summary aria-label="Open navigation">Menu</summary>
      <div class="mobile-menu-links">
        <a href={productUrl}>Products</a>
        <a href="https://developer.cafecito.tech">APIs &amp; MCPs</a>
        <a href="/blogs/">Blogs</a>
        <a href="/docs/overview/">Overview</a>
        <a href="/docs/about-us/">About us</a>
        <a href="/docs/terms-of-use/">Terms of Use</a>
        <a href="/docs/privacy-policy/">Privacy Policy</a>
        <a href="/contact/">Contact</a>
      </div>
    </details>
    <div class="nav-links">
      <a class="nav-pill" href={productUrl}>Products</a>
      <a class="nav-pill" href="https://developer.cafecito.tech">APIs &amp; MCPs</a>
      <a class="nav-pill" href="/blogs/">Blogs</a>
      <details class="company-menu">
        <summary class="nav-pill">Company</summary>
        <div class="company-menu-links">
          <a href="/docs/overview/">Overview</a>
          <a href="/docs/about-us/">About us</a>
          <a href="/docs/terms-of-use/">Terms of Use</a>
          <a href="/docs/privacy-policy/">Privacy Policy</a>
        </div>
      </details>
      <a class="nav-pill" href="/contact/">Contact</a>
    </div>
  </div>
</nav>
