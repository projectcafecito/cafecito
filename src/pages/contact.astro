---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const formEndpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT ?? '';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const formConfigured = Boolean(formEndpoint && turnstileSiteKey);
---

<BaseLayout
  title="Contact Project Cafecito"
  description="Contact Project Cafecito about products, support, partnerships, press, privacy, or other business inquiries."
>
  <Nav />
  <main class="contact-main">
    <div class="container contact-shell">
      <section class="contact-intro" aria-labelledby="contact-heading">
        <p class="eyebrow">Contact Project Cafecito</p>
        <h1 id="contact-heading">Let&rsquo;s talk about the work behind the work.</h1>
        <p class="contact-lead">
          Tell us what you are working on, where you are getting stuck, or how you would like to collaborate.
          We typically respond within two business days.
        </p>

        <aside class="contact-note shared-panel">
          <h2>Reporting a technical problem?</h2>
          <p>
            Public bugs and feature requests are still best handled through GitHub, where the project community can
            follow their progress.
          </p>
          <a href="https://github.com/soumitsalman/cafecito/issues/new/choose">Open a GitHub issue &rarr;</a>
        </aside>
      </section>

      <section class="contact-form-panel shared-panel" aria-labelledby="form-heading">
        <h2 id="form-heading">Send us a message</h2>
        <p class="form-required"><span aria-hidden="true">*</span> Required fields</p>

        <form
          id="contact-form"
          class="contact-form"
          action={formEndpoint || undefined}
          method="post"
          data-configured={String(formConfigured)}
        >
          <div class="form-row">
            <label for="name">Name <span aria-hidden="true">*</span></label>
            <input id="name" name="name" type="text" autocomplete="name" maxlength="100" required />
          </div>

          <div class="form-row">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input id="email" name="email" type="email" autocomplete="email" maxlength="254" required />
          </div>

          <div class="form-grid">
            <div class="form-row">
              <label for="inquiry-type">What can we help with? <span aria-hidden="true">*</span></label>
              <select id="inquiry-type" name="inquiry_type" required>
                <option value="">Select an inquiry</option>
                <option value="general">General inquiry</option>
                <option value="product-support">Product support</option>
                <option value="partnership">Partnership</option>
                <option value="press">Press</option>
                <option value="privacy-legal">Privacy or legal</option>
              </select>
            </div>

            <div class="form-row">
              <label for="product">Product <span class="optional">Optional</span></label>
              <select id="product" name="product">
                <option value="">Not product-specific</option>
                <option value="beans">Beans</option>
                <option value="espresso">Espresso</option>
                <option value="cortado">Cortado</option>
                <option value="medicafe">MediCafe</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>

          <div class="form-row">
            <label for="message">Message <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="8" minlength="10" maxlength="5000" required></textarea>
            <span class="field-hint">Please do not include passwords, API keys, or sensitive personal information.</span>
          </div>

          <div class="contact-honeypot" aria-hidden="true">
            <label for="company-website">Company website</label>
            <input id="company-website" name="company_website" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <input id="form-started-at" name="form_started_at" type="hidden" value="" />

          <label class="privacy-check" for="privacy-acknowledgement">
            <input id="privacy-acknowledgement" name="privacy_acknowledgement" type="checkbox" value="accepted" required />
            <span>
              I understand that Project Cafecito will use this information to respond to my inquiry, as described in
              the <a href="/docs/privacy-policy/">Privacy Policy</a>.
            </span>
          </label>

          {
            formConfigured ? (
              <div
                class="cf-turnstile"
                data-sitekey={turnstileSiteKey}
                data-theme="dark"
                data-action="contact"
              ></div>
            ) : (
              <p class="form-setup-message" role="status">
                The contact form is temporarily unavailable while secure message delivery is being configured.
                Please use GitHub for a technical inquiry.
              </p>
            )
          }

          <div class="form-submit-row">
            <button class="btn btn-primary" type="submit" disabled={!formConfigured}>Send message</button>
            <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
          </div>
        </form>
      </section>
    </div>
  </main>
  <Footer />

  {turnstileSiteKey && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('#contact-form');
  const status = document.querySelector<HTMLElement>('#form-status');
  const startedAt = document.querySelector<HTMLInputElement>('#form-started-at');
  const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  if (startedAt) startedAt.value = String(Date.now());

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (form.dataset.configured !== 'true' || !form.action || !status || !submitButton) return;
    if (!form.reportValidity()) return;

    const turnstileToken = new FormData(form).get('cf-turnstile-response');
    if (!turnstileToken) {
      status.dataset.state = 'error';
      status.textContent = 'Please complete the human verification before sending your message.';
      return;
    }

    submitButton.disabled = true;
    submitButton.textContent = 'Sending…';
    status.dataset.state = 'pending';
    status.textContent = 'Sending your message…';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (!response.ok) throw new Error('Submission failed');

      form.reset();
      if (startedAt) startedAt.value = String(Date.now());
      (window as typeof window & { turnstile?: { reset: () => void } }).turnstile?.reset();
      status.dataset.state = 'success';
      status.textContent = 'Thank you. Your message has been sent, and we will get back to you soon.';
    } catch {
      (window as typeof window & { turnstile?: { reset: () => void } }).turnstile?.reset();
      status.dataset.state = 'error';
      status.textContent = 'We could not send your message. Please try again in a moment.';
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = 'Send message';
    }
  });
</script>

<style>
  .contact-main { padding: 4rem 0 3rem; }
  .contact-shell { display: grid; grid-template-columns: minmax(0, .8fr) minmax(0, 1.2fr); gap: 2rem; align-items: start; }
  .contact-intro h1 { max-width: 12ch; margin: .65rem 0 1rem; font-size: clamp(2.4rem, 6vw, 4.4rem); }
  .contact-lead { max-width: 52ch; color: rgba(245, 239, 229, .82); font-size: 1.08rem; line-height: 1.7; }
  .contact-note { margin-top: 2rem; padding: 1.25rem; }
  .contact-note h2 { font-size: 1.05rem; }
  .contact-note p { color: rgba(245, 239, 229, .76); line-height: 1.55; }
  .contact-note a, .privacy-check a { color: var(--caramel); text-decoration: underline; }
  .contact-form-panel { padding: clamp(1.2rem, 4vw, 2rem); box-shadow: 0 22px 40px rgba(0, 0, 0, .28); }
  .contact-form-panel > h2 { font-size: clamp(1.6rem, 4vw, 2.2rem); }
  .form-required { margin: .45rem 0 1.5rem; color: rgba(245, 239, 229, .62); font-size: .82rem; }
  .contact-form, .form-row { display: grid; gap: .5rem; }
  .contact-form { gap: 1.15rem; }
  .form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .form-row label { color: var(--latte); font-size: .9rem; font-weight: 700; }
  .optional { margin-left: .3rem; color: rgba(245, 239, 229, .55); font-size: .75rem; font-weight: 400; }
  input, select, textarea { width: 100%; border: 1px solid rgba(234, 216, 191, .3); border-radius: 10px; background: rgba(10, 6, 4, .54); color: var(--foam); font: inherit; padding: .75rem .85rem; }
  select option { background: var(--ink); }
  textarea { min-height: 10rem; resize: vertical; }
  input:focus, select:focus, textarea:focus { border-color: var(--caramel); outline: 3px solid rgba(193, 129, 59, .2); }
  .field-hint { color: rgba(245, 239, 229, .56); font-size: .78rem; }
  .privacy-check { display: flex; gap: .7rem; align-items: flex-start; color: rgba(245, 239, 229, .78); font-size: .86rem; line-height: 1.5; }
  .privacy-check input { width: 1rem; height: 1rem; margin-top: .2rem; accent-color: var(--caramel); flex: 0 0 auto; }
  .contact-honeypot { position: absolute; left: -10000px; width: 1px; height: 1px; overflow: hidden; }
  .form-setup-message { margin: 0; border: 1px solid rgba(234, 216, 191, .22); border-radius: 10px; padding: .8rem; color: rgba(245, 239, 229, .72); font-size: .86rem; line-height: 1.5; }
  .form-submit-row { display: flex; align-items: center; gap: 1rem; }
  .form-submit-row .btn:disabled { cursor: not-allowed; filter: grayscale(.7); opacity: .55; transform: none; }
  .form-status { margin: 0; color: rgba(245, 239, 229, .72); font-size: .88rem; line-height: 1.45; }
  .form-status[data-state='success'] { color: #6ee7b7; }
  .form-status[data-state='error'] { color: #fca5a5; }
  @media (max-width: 820px) { .contact-main { padding-top: 2.5rem; } .contact-shell { grid-template-columns: 1fr; } .contact-intro h1 { max-width: 15ch; } }
  @media (max-width: 540px) { .form-grid { grid-template-columns: 1fr; } .form-submit-row { align-items: stretch; flex-direction: column; } }
</style>
