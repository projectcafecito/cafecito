---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Project Cafecito | Coffee-Fueled AI Products"
  description="Project Cafecito builds coffee-fueled AI products for news intelligence, market analysis, social automation, and medical billing workflows."
  keywords="AI automation, news API, market intelligence, social media automation, medical billing automation, Project Cafecito"
>
  <Nav />
  <header class="hero">
    <div class="container">
      <section class="hero-frame hero-frame--cafecito" role="img" aria-label="Coffee and AI visual for Project Cafecito">
        <article class="hero-copy">
          <p class="eyebrow">Practical AI &amp; Tools for Small Business</p>
          <h1>Automation for Business Owners</h1>
          <h4>Who'd rather do real work instead of mind-numbing admin.</h4>
          <p>We build simple, API-first AI tools and workflows that eliminate repetitive back-office tasks for small and micro businesses. No bloated platforms — just practical systems that ship fast, drink coffee with you, and free you to focus on the work you actually enjoy. Automation that fits your caffeine budget and chaos tolerance.</p>
          <div class="hero-actions"><a class="btn btn-primary" href="#products">See Product Lineup</a><a class="btn btn-secondary" href="https://developer.cafecito.tech">Dive Into API</a></div>
        </article>
      </section>
    </div>
  </header>
  <main>
    <section class="section section--spacious" id="products">
      <div class="container">
        <div class="section-title"><h2>Products</h2><p>Yes, these are real. No, we still cannot fix your printer.</p></div>
        <div class="products">
          <a class="product shared-panel shared-panel--interactive" href="/beans/"><img class="product-icon" src="/images/beans.png" alt="Beans product icon" /><div><span class="tag shared-badge shared-badge--caramel">News API</span><h3>Beans</h3><p>News &amp; blog aggregator API with semantic search, smart filters, and MCP support — so your AI workflows stay fed with relevant information, not noise.</p></div></a>
          <a class="product shared-panel shared-panel--interactive" href="/espresso/"><img class="product-icon" src="/images/espresso.png" alt="Espresso product icon" /><div><span class="tag shared-badge shared-badge--caramel">Intelligence</span><h3>Espresso</h3><p>Curated business intelligence suite — API, publications, and social digests with event signals, tags, and relationships for dashboards and AI agents.</p></div></a>
          <article class="product shared-panel"><img class="product-icon" src="/images/cortado.png" alt="Cortado product icon" /><div><span class="tag shared-badge shared-badge--caramel">Social Automation</span><h3>Cortado</h3><p>Social media automation that keeps your posting consistent, campaigns clean, and your manual wrangling to a minimum.</p></div></article>
          <article class="product shared-panel"><img class="product-icon" src="/images/medicafe.png" alt="MediCafe product icon" /><div><span class="tag shared-badge shared-badge--caramel">Medical Ops</span><h3>MediCafe</h3><p>Medical billing automation that reduces claim denials, paperwork friction, and the operational headaches that eat into your practice time.</p></div></article>
        </div>
      </div>
    </section>
    <section class="section section--spacious" id="about">
      <div class="container">
        <article class="about-copy">
          <p class="eyebrow">Meet the founders</p>
          <h2>Built by operators who got tired of busywork.</h2>
          <p class="about-lead">Project Cafecito is run by two tech-industry veterans who kept seeing the same problem: too much repetitive work and not enough time for the meaningful stuff. We are bootstrapped, experimental, and aggressively practical.</p>
          <div class="founder-grid">
            <section class="founder-card">
              <h3>Soumit Salman Rahman</h3>
              <p class="founder-role">Computer engineer · Cybersecurity · Applied AI</p>
              <p>Soumit has built secure, large-scale computing platforms and AI-enabled systems across Microsoft, Dropbox, and Aurora Innovation. He brings product, engineering, and security experience to Cafecito’s practical automation stack.</p>
              <div class="link-row"><a class="mini-link" href="https://www.linkedin.com/in/soumitsrahman/">LinkedIn</a><a class="mini-link" href="https://medium.com/@soumitsr">Writing</a></div>
            </section>
            <section class="founder-card">
              <h3>Daniel Oliver Vidaud</h3>
              <p class="founder-role">Aerospace engineer · Operations · Organizational change</p>
              <p>Daniel has led complex product and operational integrations from aerospace to consulting. He specializes in the small, counter-intuitive changes that create durable improvements across organizations.</p>
              <div class="link-row"><a class="mini-link" href="https://www.linkedin.com/in/dvidaud/">LinkedIn</a><a class="mini-link" href="https://personalizedtransformations.com/blog/">Writing</a></div>
            </section>
          </div>
          <div class="about-actions"><a class="btn btn-primary" href="/docs/about-us/">Our full story</a><a class="btn btn-secondary" href="/blogs/">Company updates</a></div>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
